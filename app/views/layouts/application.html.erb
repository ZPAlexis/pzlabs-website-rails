<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "PZLabs" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="PZLabs">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/svg+xml" href="<%= asset_path("icons/coin-gold.svg") %>">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-locale="<%= I18n.locale %>"
        data-icon-coin-idle="<%= asset_path('icons/coin_idle.gif') %>"
        data-icon-coin-spin="<%= asset_path('icons/coin_spin.gif') %>"
        data-icon-coin-gold="<%= asset_path('icons/coin-gold.svg') %>"
        data-icon-arrow-fill-right="<%= asset_path('icons/arrow-fill-right.svg') %>"
        data-rps-emojis="<%= { rock: asset_path('icons/rock-emoji.png'), paper: asset_path('icons/paper-emoji.png'), scissors: asset_path('icons/scissors-emoji.png') }.to_json %>">
    <%= render "shared/header" %>

    <%= yield %>
    
    <%= render "shared/return_to_top" %>
    <%= render "shared/image_lightbox" %>
    <%= render "shared/footer" %>

    <%= render "shared/mobile_nav" %>
  
    <%= yield :page_specific_js %>
  </body>
</html>