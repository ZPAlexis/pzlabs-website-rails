<% 
  btn_text = local_assigns.fetch(:button_text, t('index.learn_more_btn'))
  is_disabled = local_assigns[:disabled] == true 
  is_short_text = local_assigns[:short_text] == true
%>

<div class="project-container fade-right">
  <div class="project-container-top">
    <div class="project-image-container not-selectable">
      <img class="project-image" src="<%= image_path %>">
    </div>
    <div class="project-summary">
      <div class="project-summary-container">
        <h1 class="<%= class_names('project-title-text', 'project-title-text--small': is_short_text) %>"><%= title %></h1>
        <div class="project-summary-tags not-selectable">
          <% tags.each do |tag| %>
            <div class="stack-tag"><%= tag %></div>
          <% end %>
        </div>
        <button class="js-animated-button cta-button project-cta" data-action="navigate" 
          data-target="<%= path %>"
          <%= 'disabled="disabled"' if is_disabled %>>
        <%= btn_text %>
      </button>
      </div>
    </div>
  </div>
  <p class="project-description-text"><%= t(i18n_key) %></p> 
</div>