    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var idle = document.querySelector('.js-cover-idle');
        var spin = document.querySelector('.js-cover-spin');
        var busy = false;
        document.querySelector('.post-cover-coin-container').addEventListener('click', function() {
          if (busy) return;
          busy = true;
          spin.src = '';
          spin.src = '/icons/coin_spin.gif';
          spin.style.opacity = '1';
          idle.style.opacity = '0';
          setTimeout(function() {
            idle.style.opacity = '1';
            spin.style.opacity = '0';
            busy = false;
          }, 3000);
        });
      })();
    </script>
